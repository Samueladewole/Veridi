# ── DATABASE (Railway auto-injects DATABASE_URL) ──────────────────
DATABASE_URL=postgresql://veridi:password@localhost:5432/veridi_dev

# ── AUTH ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_REFRESH_SECRET=change-me-to-another-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── REDIS (Railway auto-injects REDIS_URL) ────────────────────────
REDIS_URL=redis://localhost:6379

# ── API ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003
API_VERSION=v1

# ── NEXT.JS APPS ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3002

# ── CLOUDFLARE R2 ─────────────────────────────────────────────────
CLOUDFLARE_R2_BUCKET=veridi-documents
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# ── PAYMENT ───────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...

# ── IDENTITY DATA SOURCES ─────────────────────────────────────────
NIMC_API_KEY=            # Leave blank to use mock in development
NIMC_API_URL=https://api.nimc.gov.ng/v1
NIBSS_API_KEY=           # Leave blank to use mock
NIBSS_API_URL=
FRSC_API_KEY=            # Leave blank to use mock
SMILE_IDENTITY_API_KEY=  # Phase 1 relay

# ── COMMUNICATIONS ────────────────────────────────────────────────
TERMII_API_KEY=
TERMII_SENDER_ID=Veridi

# ── ML SERVICE ────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000  # Python FastAPI service
# Leave blank to use mock liveness/face match responses
